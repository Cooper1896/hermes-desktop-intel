# Optional Electron download mirror (see docs/BUILD.md)
# ELECTRON_MIRROR=https://npmmirror.com/mirrors/electron/

# Disable auto code-signing discovery for local builds (default in scripts)
# CSC_IDENTITY_AUTO_DISCOVERY=false

# Apple Developer ID + notarization (only if you have credentials)
# CSC_LINK=/path/to/certs.p12
# CSC_KEY_PASSWORD=
# APPLE_ID=
# APPLE_APP_SPECIFIC_PASSWORD=
# APPLE_TEAM_ID=
